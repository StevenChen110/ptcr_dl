{
  "manifest_version": 3,
  "name": "PTCR缺陷检测系统",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://1.94.185.51:8000/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["Resources/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}